# Argus — AI provider credentials
# Copy this to `.env` and fill in your keys. Never commit `.env`.

# NVIDIA API (primary LLM provider — get a free key at https://build.nvidia.com/)
NVIDIA_API_KEY=
NVIDIA_MODEL=meta/llama-3.3-70b-instruct

# Gemini API (optional fallback — get a free key at https://aistudio.google.com/)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash-exp

# AI behavior tuning
AI_CACHE_TTL_SECONDS=60
AI_MIN_INTERVAL_SECONDS=5
AI_MAX_TOKENS=1024
